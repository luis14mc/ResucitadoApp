# ============================================================
# Variables de entorno — ResucitadoApp v2 Backend
# Copia este archivo a `.env` y rellena los valores reales.
# NO subir `.env` al repositorio.
# ============================================================

# --- Django ---
SECRET_KEY=django-insecure-CAMBIAME-en-produccion-genera-uno-con-get_random_secret_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2

# --- Base de Datos ---
# Local (Postgres en tu máquina):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pcr_db
# Railway inyecta automáticamente DATABASE_URL en producción.

# --- CORS ---
# En desarrollo dejamos abierto para Flutter (emulador Android, iOS sim, web).
CORS_ALLOW_ALL_ORIGINS=True
# En producción usar lista explícita:
# CORS_ALLOWED_ORIGINS=https://app.cristoresucitado.hn,https://admin.cristoresucitado.hn

# --- Proxy Lecturas ---
LECTURAS_SOURCE_URL=https://www.ciudadredonda.org/calendario-lecturas-diarias
LECTURAS_USER_AGENT=ResucitadoApp/2.0 (+contacto@cristoresucitado.hn)

# --- Railway (auto-inyectadas en producción, no las pongas aquí) ---
# PORT=8000
# RAILWAY_PUBLIC_DOMAIN=pcr-backend-production.up.railway.app
